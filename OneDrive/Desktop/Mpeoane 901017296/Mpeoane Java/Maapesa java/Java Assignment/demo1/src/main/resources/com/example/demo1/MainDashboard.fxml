<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="background" stylesheets="@../../../styles/style.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.demo1.MainDashboardController">
    <children>
        <HBox layoutX="0.0" layoutY="0.0" prefHeight="100.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox fx:id="sideBar" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="200.0" spacing="20.0" style="-fx-background-color: #011616;">
                    <children>
                        <Button fx:id="btnEmployeeManagement" mnemonicParsing="false" onAction="#handleManagement" text="Employee Management" />
                        <Button fx:id="btnSalaryCalculation" mnemonicParsing="false" onAction="#handleSalaryCalculation" text="Salary Calculation" />
                        <Button fx:id="btnPayrollReportsCharts" mnemonicParsing="false" onAction="#handleReports" text="Payroll Reports &amp; Charts" />
                        <Button fx:id="btnPayslipGeneration" mnemonicParsing="false" onAction="#handlePayslipGeneration" text="Payslip Generation" />
                        <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #04f8f8; -fx-text-fill: white;" text="Logout" />
                    </children>
                    <padding>
                        <Insets top="100.0" />
                    </padding>
                </VBox>
                <VBox fx:id="mainContent" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" style="-fx-background-color: #011616;" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="dashboardTitle" alignment="CENTER" prefHeight="41.0" prefWidth="400.0" style="-fx-background-color: #04f8f8;" text="Welcome to Payroll System" textAlignment="CENTER">
                            <font>
                                <Font name="Arial Black" size="26.0" />
                            </font>
                        </Label>
                        <StackPane fx:id="mainContentArea" maxHeight="-Infinity" prefHeight="361.0" prefWidth="400.0" VBox.vgrow="ALWAYS">
                            <children>
                                <ImageView fitHeight="231.0" fitWidth="400.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../../styles/T.jpeg" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>